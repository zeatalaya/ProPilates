# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── XION ──
NEXT_PUBLIC_XION_RPC=https://rpc.xion-testnet-2.burnt.com:443
NEXT_PUBLIC_XION_REST=https://api.xion-testnet-2.burnt.com
NEXT_PUBLIC_TREASURY_CONTRACT=your-treasury-contract-address
NEXT_PUBLIC_MARKETPLACE_CONTRACT=your-marketplace-contract-address
NEXT_PUBLIC_RECLAIM_CONTRACT=xion1qf8jtznwf0tykpg7e65gwafwp47rwxl4x2g2kldvv357s6frcjlsh2m24e
NEXT_PUBLIC_USDC_DENOM=ibc/usdc

# ── OAuth3 / Abstraxion (XION account creation) ──
# Register your app at the Abstraxion portal: https://oauth2.testnet.burnt.com/
# Docs: https://docs.burnt.com/xion/developers/getting-started-advanced/your-first-dapp/build-oauth2-app-with-xion-auth
NEXT_PUBLIC_OAUTH3_SERVER=https://oauth2.testnet.burnt.com
NEXT_PUBLIC_OAUTH3_CLIENT_ID=your-abstraxion-client-id

# ── Crossmint (USDC credit card payments) ──
# Sign up at https://crossmint.com and create a project
# Create a collection for premium subscription NFTs
# Docs: https://docs.burnt.com/xion/developers/mobile-app-development/integrate-credit-card-payments-for-digital-assets-in-your-mobile-app-using-crossmint
NEXT_PUBLIC_CROSSMINT_API_KEY=your-crossmint-client-api-key
NEXT_PUBLIC_CROSSMINT_COLLECTION_ID=your-crossmint-collection-id
NEXT_PUBLIC_CROSSMINT_PROJECT_ID=your-crossmint-project-id
NEXT_PUBLIC_CROSSMINT_ENVIRONMENT=staging

# ── Spotify ──
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
NEXT_PUBLIC_SPOTIFY_REDIRECT_URI=http://localhost:3000/api/spotify/callback

# ── Reclaim Protocol ──
RECLAIM_APP_ID=your-reclaim-app-id
RECLAIM_APP_SECRET=your-reclaim-app-secret

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
