{
  "expo": {
    "name": "ProPilates",
    "slug": "propilates",
    "version": "1.0.0",
    "scheme": "propilates",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAFC"
    },
    "ios": {
      "supportsTablet": true,
      "buildNumber": "1",
      "bundleIdentifier": "com.propilates.app",
      "infoPlist": {
        "NSCameraUsageDescription": "ProPilates needs camera access for profile photos.",
        "NSPhotoLibraryUsageDescription": "ProPilates needs photo library access for profile photos.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "associatedDomains": [
        "applinks:pro-pilates.vercel.app"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0f"
      },
      "package": "com.propilates.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "propilates"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "7f8be31b-0bfb-4359-ae26-f8c8433980ba"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "zeatalaya"
  }
}
