default_platform(:ios)

platform :ios do

  desc "Build and upload to TestFlight"
  lane :beta do
    # Increment build number safely via PlistBuddy
    plist_path = File.expand_path("ProPilates/Resources/Info.plist")
    current = `/usr/libexec/PlistBuddy -c "Print :CFBundleVersion" "#{plist_path}"`.strip.to_i
    new_build = current + 1
    `/usr/libexec/PlistBuddy -c "Set :CFBundleVersion #{new_build}" "#{plist_path}"`
    UI.message("Build number: #{new_build}")

    # Build the app
    build_app(
      project: "ProPilates.xcodeproj",
      scheme: "ProPilates",
      export_method: "app-store",
      clean: true,
      output_directory: "./build",
      output_name: "ProPilates.ipa",
      xcargs: "-allowProvisioningUpdates DEVELOPMENT_TEAM=85A34A7PB2"
    )

    # Upload to TestFlight
    upload_to_testflight(
      skip_waiting_for_build_processing: true
    )
  end

  desc "Build only (no upload)"
  lane :build do
    build_app(
      project: "ProPilates.xcodeproj",
      scheme: "ProPilates",
      export_method: "app-store",
      clean: true,
      output_directory: "./build",
      output_name: "ProPilates.ipa",
      xcargs: "-allowProvisioningUpdates DEVELOPMENT_TEAM=85A34A7PB2"
    )
  end

  desc "Run tests"
  lane :test do
    run_tests(
      project: "ProPilates.xcodeproj",
      scheme: "ProPilatesTests",
      device: "iPhone 17 Pro"
    )
  end

end
